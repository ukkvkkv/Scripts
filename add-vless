#!/usr/bin/env bash
set -Eeuo pipefail

if [[ ${EUID} -ne 0 ]]; then
  echo "Run as root" >&2
  exit 1
fi

CONFIG="/usr/local/etc/xray/config.json"
[[ ! -f "$CONFIG" ]] && { echo "Config not found"; exit 1; }

if ! jq -e '.inbounds[] | select(.tag == "vless-ru-in")' "$CONFIG" >/dev/null 2>&1; then
  echo "add-vless is only for RU server"
  exit 1
fi

NEW_UUID=$(cat /proc/sys/kernel/random/uuid)

jq --arg uuid "$NEW_UUID" '
  .inbounds[] |= if .tag == "vless-ru-in" then
    .settings.clients += [{"id": $uuid, "email": "user@multihop", "flow": "xtls-rprx-vision"}]
  else . end
' "$CONFIG" > "$CONFIG.tmp" && mv "$CONFIG.tmp" "$CONFIG"

systemctl restart xray

PUBLIC_IP=$(curl -4fsSL --max-time 5 https://ifconfig.me 2>/dev/null || hostname -I | awk '{print $1}')
PORT=$(jq -r '.inbounds[] | select(.tag=="vless-ru-in") | .port' "$CONFIG")
PBK=$(jq -r '.outbounds[] | select(.tag=="vless-to-eu") | .streamSettings.realitySettings.publicKey? // empty' "$CONFIG")
SID=$(jq -r '.inbounds[] | select(.tag=="vless-ru-in") | .streamSettings.realitySettings.shortIds[0]? // empty' "$CONFIG")
SNI=$(jq -r '.inbounds[] | select(.tag=="vless-ru-in") | .streamSettings.realitySettings.serverNames[0]? // empty' "$CONFIG")

printf '\033[0;32m%s\033[0m\n' "vless://$NEW_UUID@$PUBLIC_IP:$PORT?type=xhttp&security=reality&pbk=$PBK&sid=$SID&sni=$SNI&flow=xtls-rprx-vision&fp=firefox#VLESS-Multihop-RU"
